{
  "name": "dev-utils",
  "version": "0.5.0",
  "description": "Basic development utilities",
  "author": {
    "name": "Judi"
  },
  "userConfig": {
    "vault_path": {
      "title": "Vault path",
      "description": "Absolute path to vault root (e.g. ~/code/my-vault)",
      "type": "directory",
      "sensitive": false
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-project-dir.sh"
          }
        ]
      }
    ]
  }
}
