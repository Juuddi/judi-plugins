{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(**/*.md)",
      "Read(**/*.json)",
      "Read(**/*.sh)",
      "Read(**/*.yml)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(prettier *)",
      "Bash(markdownlint *)",
      "Bash(claude plugin validate *)",
      "Bash(qmd *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git rev-parse *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "mcp__plugin_qmd_qmd__query",
      "mcp__plugin_qmd_qmd__get",
      "mcp__plugin_qmd_qmd__multi_get",
      "mcp__plugin_qmd_qmd__status"
    ],
    "deny": [
      "Bash(./scripts/bump-version.sh *)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.ssh/**)",
      "Bash(sudo *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)"
    ]
  }
}
